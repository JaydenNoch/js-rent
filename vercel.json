{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.3"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ],
    "outputDirectory": "public",
    "env": {
        "LOG_CHANNEL": "stderr",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "DATA_CACHE_DIR": "/tmp/storage/data",
        "LARAVEL_BYPASS_MANIFEST": "true"
    }
}