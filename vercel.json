{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.3"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ],
    "outputDirectory": "public",
    "env": {
        "LOG_CHANNEL": "stderr",
        "APP_STORAGE_PATH": "/tmp/storage",
        "LARAVEL_BOOTSTRAP_CACHE": "/tmp/bootstrap/cache"
    }
}